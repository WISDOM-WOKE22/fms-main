{
  "name": "fms-main",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node scripts/copy-mediapipe.js && next dev --turbopack",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "dev:webpack": "node scripts/copy-mediapipe.js && next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:tauri:frontend": "node scripts/build-tauri-frontend.js",
    "build:app": "pnpm db:migrate:prod && node scripts/generate-build-config.js && CI=true pnpm tauri build",
    "build:app:dmg": "pnpm db:migrate:prod && node scripts/generate-build-config.js && CI=false pnpm tauri build --bundles dmg",
    "build:app:windows": "pnpm db:migrate:prod && node scripts/generate-build-config.js && node scripts/download-ffmpeg.js x86_64-pc-windows-msvc && CI=false pnpm tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "start": "next start",
    "lint": "next lint",
    "download:ffmpeg": "node scripts/download-ffmpeg.js",
    "tauri": "node scripts/download-ffmpeg.js && node scripts/generate-build-config.js && tauri",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:clear-employees": "tsx prisma/clear-employees.ts",
    "db:clear-zones-shifts": "tsx prisma/clear-zones-and-shifts.ts",
    "db:clear-admins": "tsx prisma/clear-admins.ts",
    "demo": "node ../fms-access-logs-demo/load-demo.js",
    "demo:seed": "node ../fms-access-logs-demo/create-demo-employees.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@prisma/client": "^6.19.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-http": "~2.5.7",
    "@tauri-apps/plugin-opener": "^2",
    "file-saver": "^2.0.5",
    "hls.js": "^1.6.15",
    "i18next": "^25.8.13",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "next": "^15.1.0",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3"
  }
}