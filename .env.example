# Frontend: API base URL (Python/FastAPI backend). Default: http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8001

# Database (SQLite) – Prisma uses DATABASE_URL; Python backend uses FMS_DATABASE_URL.
# Set FMS_DATABASE_URL so Python uses the same DB (path relative to src-python when running dev:backend).
# Example: FMS_DATABASE_URL="file:../prisma/dev.db"
# FMS_DATABASE_URL=

# License key (valid key for onboarding validation)
FMS_LICENSE_KEY=FMS-8A2B-4C9D-1E7F-3B6A

# Enable/disable cloud license verification.
# true (default): keys are verified against FMS_MAIN_BACKEND_URL.
# false: keys are matched locally against FMS_LICENSE_KEY only (no network calls).
FMS_LICENSE_KEY_VERIFICATION_ENABLED=false

# Environment: "development" (default) or "production".
# Production builds must set "production" — this disables dev-only license fallback.
FMS_ENV=development

# Allow local license-key fallback when the cloud backend is unreachable.
# Only effective when FMS_ENV != "production". Set to "true" for local dev/testing.
# NEVER enable in production builds.
FMS_ALLOW_DEV_LICENSE_FALLBACK=false

# App config (company)
FMS_COMPANY_NAME=EglobalSphere
FMS_COMPANY_IMAGE=

# Auth (sign-in credentials)
FMS_EMAIL=admin@eglobalsphere.com
FMS_PASSWORD=changeme
